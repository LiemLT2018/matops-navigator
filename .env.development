# Dev: KHÔNG set VITE_API_URL / BASE_URL trỏ thẳng https://localhost:7145 — dễ thiếu Authorization hoặc CORS.
# Để trống VITE_API_URL → axios gọi /api (cùng origin :8080), Vite proxy sang API bên dưới.
# API .NET https trên 7145 (tự ký):
# VITE_DEV_PROXY_TARGET=https://localhost:7145
VITE_DEV_PROXY_TARGET=http://localhost:5145
